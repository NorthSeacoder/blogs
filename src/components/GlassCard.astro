---
/**
 * GlassCard - 通用毛玻璃容器组件
 *
 * @prop variant - 毛玻璃强度: 'subtle' | 'medium' | 'strong'
 * @prop hover - 是否启用悬停效果
 * @prop padding - 内边距大小: 'none' | 'sm' | 'md' | 'lg'
 * @prop rounded - 圆角大小: 'md' | 'lg' | 'xl' | '2xl'
 * @prop as - 渲染的 HTML 标签
 */

interface Props {
  variant?: 'subtle' | 'medium' | 'strong';
  hover?: boolean;
  padding?: 'none' | 'sm' | 'md' | 'lg';
  rounded?: 'md' | 'lg' | 'xl' | '2xl';
  as?: 'div' | 'section' | 'article' | 'aside';
  class?: string;
}

const {
  variant = 'medium',
  hover = false,
  padding = 'md',
  rounded = 'xl',
  as: Tag = 'div',
  class: className = '',
} = Astro.props;

const variantClasses = {
  subtle: 'glass-subtle',
  medium: 'glass',
  strong: 'glass-strong',
};

const paddingClasses = {
  none: '',
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8',
};

const roundedClasses = {
  md: 'rounded-md',
  lg: 'rounded-lg',
  xl: 'rounded-xl',
  '2xl': 'rounded-2xl',
};

const hoverClasses = hover
  ? 'transition-all duration-300 hover:shadow-xl hover:shadow-accent/5 hover:-translate-y-0.5'
  : '';
---

<Tag
  class:list={[
    variantClasses[variant],
    paddingClasses[padding],
    roundedClasses[rounded],
    hoverClasses,
    className,
  ]}
>
  <slot />
</Tag>

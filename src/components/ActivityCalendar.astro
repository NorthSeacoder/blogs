---
/**
 * ActivityCalendar - 发布日历热力图组件
 * GitHub 风格的活动热力图
 */
import type { CollectionEntry } from 'astro:content';
import CodeWindow from './CodeWindow.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;

// 生成过去 6 个月的日期数据
const today = new Date();
const sixMonthsAgo = new Date(today);
sixMonthsAgo.setMonth(sixMonthsAgo.getMonth() - 6);

// 统计每天的文章数
const postCountByDate = new Map<string, number>();
posts.forEach((post) => {
  const dateStr = post.data.pubDate.toISOString().split('T')[0];
  postCountByDate.set(dateStr, (postCountByDate.get(dateStr) || 0) + 1);
});

// 生成日历数据（简化版：显示最近 20 周）
const weeks: { date: Date; count: number }[][] = [];
let currentWeek: { date: Date; count: number }[] = [];

// 从 20 周前的周日开始
const startDate = new Date(today);
startDate.setDate(startDate.getDate() - (20 * 7) - startDate.getDay());

for (let i = 0; i < 20 * 7; i++) {
  const date = new Date(startDate);
  date.setDate(date.getDate() + i);
  const dateStr = date.toISOString().split('T')[0];
  const count = postCountByDate.get(dateStr) || 0;

  currentWeek.push({ date, count });

  if (currentWeek.length === 7) {
    weeks.push(currentWeek);
    currentWeek = [];
  }
}

// 获取热力图等级
const getHeatLevel = (count: number): number => {
  if (count === 0) return 0;
  if (count === 1) return 1;
  if (count === 2) return 2;
  if (count <= 4) return 3;
  return 4;
};

// 月份标签
const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
---

<CodeWindow filename="activity.ts" showControls={false}>
  <div class="font-mono text-xs">
    <p class="syntax-comment">// 发布日历</p>

    <!-- 月份标签 -->
    <div class="mt-2 flex gap-0.5 text-[10px] text-[var(--color-text-muted)] mb-1">
      {weeks.filter((_, i) => i % 4 === 0).map((week) => (
        <span class="w-[52px]">{months[week[0].date.getMonth()]}</span>
      ))}
    </div>

    <!-- 热力图 -->
    <div class="flex gap-0.5">
      {weeks.map((week) => (
        <div class="flex flex-col gap-0.5">
          {week.map((day) => (
            <div
              class={`w-3 h-3 rounded-sm heatmap-${getHeatLevel(day.count)}`}
              title={`${day.date.toISOString().split('T')[0]}: ${day.count} 篇文章`}
            />
          ))}
        </div>
      ))}
    </div>

    <!-- 图例 -->
    <div class="mt-2 flex items-center gap-1 text-[10px] text-[var(--color-text-muted)]">
      <span>Less</span>
      <div class="flex gap-0.5">
        {[0, 1, 2, 3, 4].map((level) => (
          <div class={`w-3 h-3 rounded-sm heatmap-${level}`} />
        ))}
      </div>
      <span>More</span>
    </div>
  </div>
</CodeWindow>

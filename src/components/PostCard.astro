---
import type { CollectionEntry } from 'astro:content';
import Icon from './Icon.astro';
import { format, getPostDisplayTitle, getSeriesName, isSeriesIndex } from '../lib/utils';

interface Props {
  post: CollectionEntry<'blog'>;
  index?: number;
  showSeries?: boolean;
}

const { post, index = 0, showSeries = true } = Astro.props;
const animationDelay = `${index * 50}ms`;
const seriesName = getSeriesName(post);
const displayTitle = getPostDisplayTitle(post);
const isIndexPost = isSeriesIndex(post);
---

<article
  class="
    group relative
    code-window
    transition-all duration-200
    hover:border-[var(--color-accent)]
    animate-slide-up animate-fill-backwards
    cursor-pointer
  "
  style={`animation-delay: ${animationDelay};`}
>
  <!-- 标题栏 -->
  <div class="code-window-titlebar">
    <div class="window-controls">
      <span class="window-control window-control-close" />
      <span class="window-control window-control-minimize" />
      <span class="window-control window-control-maximize" />
    </div>
    <span class="flex-1 text-center font-mono text-xs text-[var(--color-text-secondary)]">
      {post.slug}.md
    </span>
    <div class="w-[52px]" />
  </div>

  <!-- 内容区域 -->
  <a href={`/posts/${post.slug}/`} class="block p-4">
    <!-- 系列标签 -->
    {
      showSeries && seriesName && (
        <div class="mb-2">
          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-mono bg-[var(--color-accent)]/10 text-[var(--color-accent)]">
            <Icon name="folder" size={3} />
            {isIndexPost ? `我不知道的 ${seriesName} / 系列导读` : `我不知道的 ${seriesName}`}
          </span>
        </div>
      )
    }

    <!-- 标题 -->
    <h3 class="font-mono text-base font-medium text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors">
      {displayTitle}
    </h3>

    <!-- 描述 -->
    <p class="mt-2 text-sm text-[var(--color-text-secondary)] line-clamp-2">
      {post.data.description}
    </p>

    <!-- 元信息 -->
    <div class="mt-3 flex items-center gap-4 text-xs font-mono text-[var(--color-text-muted)]">
      <span class="flex items-center gap-1">
        <Icon name="calendar" size={3} />
        <time datetime={post.data.pubDate.toISOString()}>
          {format.date(post.data.pubDate)}
        </time>
      </span>

      {
        post.data.tags && post.data.tags.length > 0 && (
          <span class="flex items-center gap-1">
            <Icon name="tag" size={3} />
            {post.data.tags.slice(0, 2).join(', ')}
            {post.data.tags.length > 2 && ` +${post.data.tags.length - 2}`}
          </span>
        )
      }
    </div>
  </a>

  <!-- 悬停指示器 -->
  <div
    class="
      absolute right-4 top-1/2 -translate-y-1/2
      opacity-0 group-hover:opacity-100
      transition-opacity
      text-[var(--color-accent)]
    "
  >
    <Icon name="chevron-right" size={4} />
  </div>
</article>

---
/**
 * SeriesList - 系列列表组件
 */
import type { CollectionEntry } from 'astro:content';
import CodeWindow from './CodeWindow.astro';
import Icon from './Icon.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
  limit?: number;
}

const { posts, limit = 5 } = Astro.props;

// 统计系列
const seriesMap = new Map<string, number>();
posts.forEach((post) => {
  let seriesName = post.data.series;

  // 如果没有 series 字段，从标题解析
  if (!seriesName) {
    const match = post.data.title.match(/^我不知道的\s*(.+?)\s*[-–—]/);
    if (match) seriesName = match[1];
  }

  if (seriesName) {
    seriesMap.set(seriesName, (seriesMap.get(seriesName) || 0) + 1);
  }
});

// 按数量排序
const series = Array.from(seriesMap.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, limit);
---

{series.length > 0 && (
  <CodeWindow filename="series.ts" showControls={false}>
    <div class="font-mono text-xs">
      <p class="syntax-comment">// 文章系列</p>
      <p class="mt-2">
        <span class="syntax-keyword">const</span>
        <span class="syntax-variable"> series</span>
        <span class="text-[var(--color-text-primary)]"> = {'{'}</span>
      </p>

      {series.map(([name, count]) => (
        <a
          href={`/series/${encodeURIComponent(name)}/`}
          class="
            block pl-4 py-1
            transition-colors
            hover:bg-[var(--color-surface-hover)]
            rounded
          "
        >
          <span class="syntax-string">"我不知道的 {name}"</span>
          <span class="text-[var(--color-text-primary)]">: </span>
          <span class="syntax-number">{count}</span>
          <span class="text-[var(--color-text-primary)]">,</span>
        </a>
      ))}

      <p class="text-[var(--color-text-primary)]">{'}'};</p>

      <a
        href="/series/"
        class="
          mt-2 inline-flex items-center gap-1
          text-[var(--color-accent)]
          hover:underline
        "
      >
        <span class="syntax-comment">// 查看全部系列 →</span>
      </a>
    </div>
  </CodeWindow>
)}

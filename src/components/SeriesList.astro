---
/**
 * SeriesList - 系列列表组件
 */
import type { CollectionEntry } from 'astro:content';
import CodeWindow from './CodeWindow.astro';
import { groupSeriesPosts } from '../lib/utils';

interface Props {
  posts: CollectionEntry<'blog'>[];
  limit?: number;
}

const { posts, limit = 5 } = Astro.props;
const series = groupSeriesPosts(posts).slice(0, limit);
---

{series.length > 0 && (
  <CodeWindow filename="series.ts" showControls={false}>
    <div class="font-mono text-xs">
      <p class="syntax-comment">// 文章系列</p>
      <p class="mt-2">
        <span class="syntax-keyword">const</span>
        <span class="syntax-variable"> series</span>
        <span class="text-[var(--color-text-primary)]"> = {'{'}</span>
      </p>

      {series.map((group) => (
        <a
          href={`/series/${encodeURIComponent(group.name)}/`}
          class="
            block pl-4 py-1
            transition-colors
            hover:bg-[var(--color-surface-hover)]
            rounded
          "
        >
          <span class="syntax-string">"我不知道的 {group.name}"</span>
          <span class="text-[var(--color-text-primary)]">: </span>
          <span class="syntax-number">{group.posts.length}</span>
          <span class="text-[var(--color-text-primary)]">,</span>
        </a>
      ))}

      <p class="text-[var(--color-text-primary)]">{'}'};</p>

      <a
        href="/series/"
        class="
          mt-2 inline-flex items-center gap-1
          text-[var(--color-accent)]
          hover:underline
        "
      >
        <span class="syntax-comment">// 查看全部系列 →</span>
      </a>
    </div>
  </CodeWindow>
)}

---
/**
 * Icon - 统一的 SVG 图标组件
 *
 * @prop name - 图标名称
 * @prop size - 图标尺寸 (默认 4 = 1rem)
 * @prop class - 额外的 CSS 类
 */

type IconName =
  'rss' | 'sitemap' | 'home' | 'search' | 'arrow-right' | 'arrow-left' |
  'chevron-right' | 'calendar' | 'calendar-filled' | 'clock' | 'refresh' |
  'share' | 'github';

interface Props {
  name: IconName;
  size?: number;
  class?: string;
}

const { name, size = 4, class: className = '' } = Astro.props;
const sizeClass = `h-${size} w-${size}`;

// 图标路径定义
const icons: Record<IconName, { viewBox: string; fill?: boolean; paths: string[] }> = {
  rss: {
    viewBox: '0 0 24 24',
    fill: true,
    paths: [
      'M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z',
    ],
  },
  sitemap: {
    viewBox: '0 0 24 24',
    paths: [
      'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7',
    ],
  },
  home: {
    viewBox: '0 0 24 24',
    paths: [
      'M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25',
    ],
  },
  search: {
    viewBox: '0 0 24 24',
    paths: ['M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z'],
  },
  'arrow-right': {
    viewBox: '0 0 24 24',
    paths: ['M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3'],
  },
  'arrow-left': {
    viewBox: '0 0 24 24',
    paths: ['M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18'],
  },
  'chevron-right': {
    viewBox: '0 0 24 24',
    paths: ['M8.25 4.5l7.5 7.5-7.5 7.5'],
  },
  calendar: {
    viewBox: '0 0 24 24',
    paths: [
      'M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5',
    ],
  },
  'calendar-filled': {
    viewBox: '0 0 20 20',
    fill: true,
    paths: [
      'M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z',
    ],
  },
  clock: {
    viewBox: '0 0 24 24',
    paths: ['M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z'],
  },
  refresh: {
    viewBox: '0 0 24 24',
    paths: [
      'M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99',
    ],
  },
  share: {
    viewBox: '0 0 24 24',
    paths: [
      'M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z',
    ],
  },
  github: {
    viewBox: '0 0 24 24',
    fill: true,
    paths: [
      'M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z',
    ],
  },
};

const icon = icons[name];
const isFilled = icon.fill === true;
---

<svg
  class:list={[sizeClass, className]}
  fill={isFilled ? 'currentColor' : 'none'}
  viewBox={icon.viewBox}
  stroke={isFilled ? undefined : 'currentColor'}
  stroke-width={isFilled ? undefined : '2'}
  aria-hidden="true"
>
  {
    icon.paths.map((d) => (
      <path
        stroke-linecap={isFilled ? undefined : 'round'}
        stroke-linejoin={isFilled ? undefined : 'round'}
        fill-rule={isFilled && name === 'calendar-filled' ? 'evenodd' : undefined}
        clip-rule={isFilled && name === 'calendar-filled' ? 'evenodd' : undefined}
        d={d}
      />
    ))
  }
</svg>

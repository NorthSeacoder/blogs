---
/**
 * Icon - 使用 Lucide 图标库的统一图标组件
 *
 * @prop name - 图标名称 (Lucide 图标名)
 * @prop size - 图标尺寸 (默认 4 = 1rem)
 * @prop class - 额外的 CSS 类
 */
import { Icon as AstroIcon } from 'astro-icon/components';

// 图标名称映射 (旧名称 -> Lucide 名称)
const iconMap: Record<string, string> = {
  'rss': 'lucide:rss',
  'sitemap': 'lucide:map',
  'home': 'lucide:home',
  'search': 'lucide:search',
  'arrow-right': 'lucide:arrow-right',
  'arrow-left': 'lucide:arrow-left',
  'chevron-right': 'lucide:chevron-right',
  'chevron-left': 'lucide:chevron-left',
  'calendar': 'lucide:calendar',
  'calendar-filled': 'lucide:calendar-days',
  'clock': 'lucide:clock',
  'refresh': 'lucide:refresh-cw',
  'share': 'lucide:share-2',
  'github': 'lucide:github',
  'folder': 'lucide:folder',
  'tag': 'lucide:tag',
  'mail': 'lucide:mail',
  'file-text': 'lucide:file-text',
  'user': 'lucide:user',
  'sun': 'lucide:sun',
  'moon': 'lucide:moon',
  'monitor': 'lucide:monitor',
  'external-link': 'lucide:external-link',
  'code': 'lucide:code',
  'terminal': 'lucide:terminal',
  'book': 'lucide:book-open',
  'hash': 'lucide:hash',
  'list': 'lucide:list',
  'menu': 'lucide:menu',
  'x': 'lucide:x',
  'check': 'lucide:check',
  'copy': 'lucide:copy',
  'link': 'lucide:link',
  'eye': 'lucide:eye',
  'heart': 'lucide:heart',
  'star': 'lucide:star',
  'message': 'lucide:message-circle',
};

interface Props {
  name: string;
  size?: number;
  class?: string;
}

const { name, size = 4, class: className = '' } = Astro.props;

// 获取 Lucide 图标名称
const iconName = iconMap[name] || `lucide:${name}`;

// 计算尺寸 (size * 0.25rem)
const sizeRem = size * 0.25;
---

<AstroIcon
  name={iconName}
  class={className}
  style={`width: ${sizeRem}rem; height: ${sizeRem}rem;`}
/>

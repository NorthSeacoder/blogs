---
/**
 * TagCloud - 标签云组件（代码风格）
 */
import type { CollectionEntry } from 'astro:content';
import CodeWindow from './CodeWindow.astro';
import { getTagPath } from '../lib/utils';

interface Props {
  posts: CollectionEntry<'blog'>[];
  limit?: number;
}

const { posts, limit = 10 } = Astro.props;

// 统计标签
const tagMap = new Map<string, number>();
posts.forEach((post) => {
  post.data.tags?.forEach((tag) => {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  });
});

// 按数量排序，取前 N 个
const tags = Array.from(tagMap.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, limit);
---

<CodeWindow filename="tags.ts" showControls={false}>
  <div class="font-mono text-xs leading-relaxed">
    <p><span class="syntax-keyword">const</span><span class="syntax-variable">&nbsp;tags</span><span class="text-[var(--color-text-primary)]">&nbsp;=&nbsp;{'{'}</span></p>

    {tags.map(([tag, count], index) => (
      <p class="pl-4">
        <a
          href={getTagPath(tag)}
          class="inline-flex items-baseline gap-0 hover:text-[var(--color-accent)] transition-colors"
        >
          <span class="syntax-string">"{tag}"</span><span class="text-[var(--color-text-primary)]">:</span>&nbsp;<span class="syntax-number">{count}</span>
        </a>
        <span class="text-[var(--color-text-primary)]">{index < tags.length - 1 ? ',' : ''}</span>
      </p>
    ))}

    <p>
      <span class="text-[var(--color-text-primary)]">{'}'}</span>
      <span class="text-[var(--color-text-primary)]">;</span>
    </p>

    {tags.length > 0 && (
      <a
        href="/tags/"
        class="mt-3 inline-block text-[var(--color-comment)] hover:text-[var(--color-accent)] transition-colors"
      >
        // 查看全部 →
      </a>
    )}
  </div>
</CodeWindow>

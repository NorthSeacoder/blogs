---
import '../styles/global.css';
import { navLinks, siteConfig } from '../lib/siteConfig';
import Seo from '../components/Seo.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import Icon from '../components/Icon.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  lang?: string;
  keywords?: string[];
  jsonLd?: Record<string, unknown>;
  wide?: boolean;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  canonical,
  image,
  lang = siteConfig.language,
  keywords,
  jsonLd,
  wide = false,
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang={lang} class="min-h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- 防闪烁脚本：在 DOM 解析前执行 -->
    <script is:inline>
      (function () {
        const STORAGE_KEY = 'theme';
        const stored = localStorage.getItem(STORAGE_KEY);
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

        // 根据存储值或系统偏好设置主题
        if (stored === 'dark' || (stored === 'system' && prefersDark) || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>

    <!-- 字体预加载 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <Seo
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      keywords={keywords}
      jsonLd={jsonLd}
    />
  </head>
  <body class="flex min-h-screen flex-col">
    <!-- 跳过链接 -->
    <a href="#main" class="skip-link">跳到主要内容</a>

    <!-- 导航栏 - VSCode 标签页风格 -->
    <header
      class="
        fixed inset-x-0 top-0 z-50
        bg-[var(--color-titlebar)]
        border-b border-[var(--color-border)]
        transition-colors duration-200
      "
    >
      <div class="main-container flex h-12 items-center justify-between">
        <!-- Logo - 终端风格 -->
        <a
          href="/"
          class="
            flex items-center gap-2
            font-mono text-sm font-medium
            text-[var(--color-text-primary)]
            transition-opacity hover:opacity-80
          "
        >
          <span class="text-[var(--color-accent)]">~/</span>
          <span>{siteConfig.title.toLowerCase().replace(/\s+/g, '-')}</span>
          <span class="text-[var(--color-comment)]">$</span>
        </a>

        <!-- 导航标签页 -->
        <div class="flex items-center">
          <nav aria-label="主导航" class="flex items-center">
            {
              navLinks.map((link) => {
                const isActive =
                  currentPath === link.href ||
                  (link.href !== '/' && currentPath.startsWith(link.href));
                return (
                  <a
                    href={link.href}
                    class:list={[
                      'tab font-mono text-xs',
                      isActive && 'active',
                    ]}
                    aria-current={isActive ? 'page' : undefined}
                  >
                    {link.label}
                  </a>
                );
              })
            }
          </nav>

          <!-- 工具栏按钮组 -->
          <div class="flex items-center gap-1 ml-2">
            <!-- 搜索按钮 -->
            <a
              href="/search/"
              class="
                flex items-center justify-center
                h-7 w-7 rounded
                text-[var(--color-text-secondary)]
                bg-[var(--color-surface)]
                border border-[var(--color-border)]
                transition-colors
                hover:bg-[var(--color-surface-hover)]
                hover:text-[var(--color-text-primary)]
              "
              aria-label="搜索"
              title="搜索 (⌘K)"
            >
              <Icon name="search" size={3.5} />
            </a>

            <!-- 主题切换 -->
            <ThemeToggle />
          </div>
        </div>
      </div>
    </header>

    <!-- 主内容区 -->
    <main
      id="main"
      class:list={[wide ? 'main-container-wide' : 'main-container', 'w-full flex-1 pb-16 pt-20']}
    >
      <slot />
    </main>

    <!-- 页脚 - VSCode 状态栏风格 -->
    <footer
      class="
        border-t border-[var(--color-border)]
        bg-[var(--color-surface)]
        py-6
        text-xs font-mono text-[var(--color-text-secondary)]
      "
    >
      <div class="main-container">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <!-- 版权信息 -->
          <p class="text-center sm:text-left">
            <span class="syntax-comment">// </span>
            <span class="syntax-keyword">const</span>
            <span class="syntax-variable"> copyright</span>
            <span> = </span>
            <span class="syntax-string">"{new Date().getFullYear()} {siteConfig.author}"</span>
          </p>

          <!-- 链接 -->
          <div class="flex items-center justify-center gap-4 sm:justify-end">
            <a
              href="/rss.xml"
              class="
                flex items-center gap-1.5
                transition-colors
                hover:text-[var(--color-accent)]
              "
              aria-label="RSS 订阅"
            >
              <Icon name="rss" size={3.5} />
              <span>RSS</span>
            </a>
            <a
              href={siteConfig.social.github}
              target="_blank"
              rel="noopener noreferrer"
              class="
                flex items-center gap-1.5
                transition-colors
                hover:text-[var(--color-accent)]
              "
              aria-label="GitHub"
            >
              <Icon name="github" size={3.5} />
              <span>GitHub</span>
            </a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

---
/**
 * 系列详情页
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CodeWindow from '../../../components/CodeWindow.astro';
import PostCard from '../../../components/PostCard.astro';
import Icon from '../../../components/Icon.astro';
import { getCollection } from 'astro:content';
import { filterDrafts, groupSeriesPosts, sortPosts } from '../../../lib/utils';

export async function getStaticPaths() {
  const posts = sortPosts(filterDrafts(await getCollection('blog')));
  return groupSeriesPosts(posts).map((group) => ({
    params: { series: group.name },
    props: { series: group.name },
  }));
}

interface Props {
  series: string;
}

const { series } = Astro.props;
const allPosts = sortPosts(filterDrafts(await getCollection('blog')));
const seriesGroup = groupSeriesPosts(allPosts).find((group) => group.name === series);
const seriesPosts = seriesGroup?.posts ?? [];
const indexPost = seriesGroup?.indexPost;
const renderedIndex = indexPost ? await indexPost.render() : null;
const SeriesIndexContent = renderedIndex?.Content;
const seriesDescription =
  indexPost?.data.description ?? `「我不知道的 ${series}」系列文章`;
---

<BaseLayout title={`我不知道的 ${series}`} description={seriesDescription}>
  <div class="max-w-3xl mx-auto animate-fade-in">
    <!-- 页面标题 -->
    <CodeWindow filename={`${series.toLowerCase().replace(/\s+/g, '-')}.ts`} class="mb-6">
      <div class="font-mono text-sm">
        <p class="syntax-comment">/**</p>
        <p class="syntax-comment"> * 我不知道的 {series}</p>
        <p class="syntax-comment"> * 共 {seriesPosts.length} 篇文章</p>
        <p class="syntax-comment"> */</p>

        <p class="mt-4">
          <span class="syntax-keyword">export const</span>
          <span class="syntax-variable"> series</span>
          <span class="text-[var(--color-text-primary)]"> = {'{'}</span>
        </p>
        <p class="pl-4">
          <span class="syntax-variable">name</span>
          <span class="text-[var(--color-text-primary)]">: </span>
          <span class="syntax-string">"我不知道的 {series}"</span>
          <span class="text-[var(--color-text-primary)]">,</span>
        </p>
        <p class="pl-4">
          <span class="syntax-variable">count</span>
          <span class="text-[var(--color-text-primary)]">: </span>
          <span class="syntax-number">{seriesPosts.length}</span>
          <span class="text-[var(--color-text-primary)]">,</span>
        </p>
        {
          indexPost && (
            <p class="pl-4">
              <span class="syntax-variable">guide</span>
              <span class="text-[var(--color-text-primary)]">: </span>
              <a href={`/posts/${indexPost.slug}/`} class="syntax-string hover:underline">
                "{indexPost.data.title}"
              </a>
              <span class="text-[var(--color-text-primary)]">,</span>
            </p>
          )
        }
        {
          indexPost?.data.description && (
            <p class="pl-4">
              <span class="syntax-variable">description</span>
              <span class="text-[var(--color-text-primary)]">: </span>
              <span class="syntax-string">"{indexPost.data.description}"</span>
              <span class="text-[var(--color-text-primary)]">,</span>
            </p>
          )
        }
        <p class="text-[var(--color-text-primary)]">{'}'};</p>
      </div>
    </CodeWindow>

    {
      SeriesIndexContent && (
        <section class="mb-8">
          <div
            class="
              prose prose-lg
              prose-headings:font-bold
              prose-a:text-accent prose-a:no-underline hover:prose-a:underline
              prose-code:before:content-none prose-code:after:content-none
              max-w-none
            "
          >
            <SeriesIndexContent />
          </div>

          <div class="mt-4">
            <a
              href={`/posts/${indexPost?.slug}/`}
              class="font-mono text-xs text-[var(--color-accent)] hover:underline"
            >
              查看系列导读原文 →
            </a>
          </div>
        </section>
      )
    }

    <!-- 文章列表 -->
    <div class="space-y-3">
      {seriesPosts.map((post, index) => (
        <PostCard post={post} index={index} showSeries={false} />
      ))}
    </div>

    {
      !SeriesIndexContent && seriesPosts.length === 0 && (
        <CodeWindow filename="empty.ts" class="mt-4">
          <p class="font-mono text-sm text-[var(--color-text-secondary)]">
            <span class="syntax-comment">// 该系列内容还在整理中</span>
          </p>
        </CodeWindow>
      )
    }

    <!-- 返回链接 -->
    <div class="mt-6">
      <a
        href="/series/"
        class="
          inline-flex items-center gap-1
          font-mono text-xs
          text-[var(--color-accent)]
          hover:underline
        "
      >
        <Icon name="chevron-left" size={3} />
        <span>返回系列列表</span>
      </a>
    </div>
  </div>
</BaseLayout>

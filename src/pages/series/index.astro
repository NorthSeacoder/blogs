---
/**
 * 系列列表页
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import CodeWindow from '../../components/CodeWindow.astro';
import { getCollection } from 'astro:content';
import { filterDrafts, getPostDisplayTitle, groupSeriesPosts, sortPosts } from '../../lib/utils';

const posts = sortPosts(filterDrafts(await getCollection('blog')));
const series = groupSeriesPosts(posts);
---

<BaseLayout title="系列" description="按系列浏览文章">
  <div class="max-w-3xl mx-auto animate-fade-in">
    <!-- 页面标题 -->
    <div class="mb-6">
      <h1 class="font-mono text-sm text-[var(--color-text-secondary)]">
        <span class="syntax-comment">// </span>
        <span class="syntax-variable">series</span>
        <span class="text-[var(--color-text-muted)]">/index.ts</span>
      </h1>
    </div>

    <!-- 系列列表 -->
    {series.length > 0 ? (
      <div class="space-y-4">
        {series.map((group) => (
          <CodeWindow filename={`${group.name.toLowerCase().replace(/\s+/g, '-')}.ts`}>
            <div class="font-mono text-sm">
              <p class="syntax-comment">// 我不知道的 {group.name}</p>
              <p class="mt-2">
                <span class="syntax-keyword">export const</span>
                <span class="syntax-variable"> series</span>
                <span class="text-[var(--color-text-primary)]"> = {'{'}</span>
              </p>
              <p class="pl-4">
                <span class="syntax-variable">name</span>
                <span class="text-[var(--color-text-primary)]">: </span>
                <span class="syntax-string">"我不知道的 {group.name}"</span>
                <span class="text-[var(--color-text-primary)]">,</span>
              </p>
              <p class="pl-4">
                <span class="syntax-variable">count</span>
                <span class="text-[var(--color-text-primary)]">: </span>
                <span class="syntax-number">{group.posts.length}</span>
                <span class="text-[var(--color-text-primary)]">,</span>
              </p>
              {
                group.indexPost && (
                  <p class="pl-4">
                    <span class="syntax-variable">guide</span>
                    <span class="text-[var(--color-text-primary)]">: </span>
                    <a href={`/posts/${group.indexPost.slug}/`} class="syntax-string hover:underline">
                      "{group.indexPost.data.title}"
                    </a>
                    <span class="text-[var(--color-text-primary)]">,</span>
                  </p>
                )
              }
              {
                group.indexPost?.data.description && (
                  <p class="pl-4">
                    <span class="syntax-variable">description</span>
                    <span class="text-[var(--color-text-primary)]">: </span>
                    <span class="syntax-string">"{group.indexPost.data.description}"</span>
                    <span class="text-[var(--color-text-primary)]">,</span>
                  </p>
                )
              }
              <p class="pl-4">
                <span class="syntax-variable">posts</span>
                <span class="text-[var(--color-text-primary)]">: [</span>
              </p>

              {group.posts.slice(0, 3).map((post) => (
                <a
                  href={`/posts/${post.slug}/`}
                  class="
                    block pl-8 py-1
                    transition-colors
                    hover:bg-[var(--color-surface-hover)]
                    rounded
                  "
                >
                  <span class="syntax-string">"{getPostDisplayTitle(post)}"</span>
                  <span class="text-[var(--color-text-primary)]">,</span>
                </a>
              ))}

              {group.posts.length > 3 && (
                <p class="pl-8 text-[var(--color-text-muted)]">
                  // ... 还有 {group.posts.length - 3} 篇
                </p>
              )}

              <p class="pl-4 text-[var(--color-text-primary)]">],</p>
              <p class="text-[var(--color-text-primary)]">{'}'};</p>

              <a
                href={`/series/${encodeURIComponent(group.name)}/`}
                class="
                  mt-3 inline-flex items-center gap-1
                  text-[var(--color-accent)]
                  hover:underline
                "
              >
                <span>查看全部 →</span>
              </a>
            </div>
          </CodeWindow>
        ))}
      </div>
    ) : (
      <CodeWindow filename="empty.ts">
        <p class="font-mono text-sm text-[var(--color-text-secondary)]">
          <span class="syntax-comment">// 暂无系列文章</span>
        </p>
      </CodeWindow>
    )}
  </div>
</BaseLayout>

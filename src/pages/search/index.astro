---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="站内搜索" description="使用 Pagefind 搜索全文内容。">
  <div class="animate-fade-in">
    <!-- 页面标题 -->
    <div class="mb-8">
      <div class="flex items-center gap-3">
        <div class="h-8 w-1 rounded-full bg-gradient-to-b from-accent to-cyan-500"></div>
        <h1 class="text-3xl font-bold text-text-primary">站内搜索</h1>
      </div>
      <p class="mt-2 text-text-secondary">
        按下 <kbd class="rounded bg-surface-elevated px-2 py-0.5 text-xs font-mono">/</kbd> 可直接聚焦输入框
      </p>
    </div>

    <!-- 搜索容器 -->
    <div id="search" class="glass rounded-2xl p-6"></div>
  </div>

  <!-- Pagefind 样式覆盖 -->
  <style is:global>
    :root {
      --pagefind-ui-scale: 1;
      --pagefind-ui-primary: var(--color-accent);
      --pagefind-ui-text: var(--color-text-primary);
      --pagefind-ui-background: transparent;
      --pagefind-ui-border: var(--color-border);
      --pagefind-ui-tag: var(--color-accent);
      --pagefind-ui-border-width: 1px;
      --pagefind-ui-border-radius: 12px;
      --pagefind-ui-image-border-radius: 8px;
      --pagefind-ui-image-box-ratio: 3 / 2;
      --pagefind-ui-font: inherit;
    }

    .pagefind-ui__search-input {
      background: var(--glass-bg) !important;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border: 1px solid var(--glass-border) !important;
      color: var(--color-text-primary) !important;
      transition: all 0.2s ease !important;
    }

    .pagefind-ui__search-input:focus {
      border-color: var(--color-accent) !important;
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1) !important;
      outline: none !important;
    }

    .pagefind-ui__search-input::placeholder {
      color: var(--color-text-secondary) !important;
    }

    .pagefind-ui__result {
      background: var(--glass-bg) !important;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border: 1px solid var(--glass-border) !important;
      border-radius: 12px !important;
      padding: 1rem !important;
      transition: all 0.2s ease !important;
    }

    .pagefind-ui__result:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    }

    .pagefind-ui__result-link {
      color: var(--color-text-primary) !important;
      font-weight: 600 !important;
    }

    .pagefind-ui__result-link:hover {
      color: var(--color-accent) !important;
    }

    .pagefind-ui__result-excerpt {
      color: var(--color-text-secondary) !important;
    }

    .pagefind-ui__message {
      color: var(--color-text-secondary) !important;
    }

    .pagefind-ui__button {
      background: var(--color-accent) !important;
      color: white !important;
      border-radius: 8px !important;
      transition: all 0.2s ease !important;
    }

    .pagefind-ui__button:hover {
      opacity: 0.9 !important;
      transform: translateY(-1px);
    }

    mark.pagefind-ui__result-highlight {
      background: rgba(59, 130, 246, 0.2) !important;
      color: var(--color-accent) !important;
      padding: 0 2px;
      border-radius: 2px;
    }
  </style>

  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script src="/pagefind/pagefind-ui.js" type="text/javascript"></script>
  <script type="text/javascript">
    document.addEventListener('DOMContentLoaded', () => {
      // @ts-ignore
      const ui = new PagefindUI({
        element: '#search',
        showSubResults: true,
        autofocus: true,
        translations: {
          placeholder: '搜索文章...',
          zero_results: '没有找到相关结果',
          many_results: '找到 [COUNT] 条结果',
          one_result: '找到 1 条结果',
          alt_search: '没有找到结果，尝试搜索 [TERM]',
          search_label: '搜索本站',
          filters_label: '筛选',
          load_more: '加载更多',
        },
      });

      window.addEventListener('keydown', (event) => {
        if (event.key === '/' && document.activeElement?.tagName !== 'INPUT') {
          event.preventDefault();
          const input = document.querySelector<HTMLInputElement>('#search input');
          if (input) input.focus();
        }
      });
    });

    // 支持 Astro View Transitions
    document.addEventListener('astro:after-swap', () => {
      // @ts-ignore
      if (typeof PagefindUI !== 'undefined') {
        // @ts-ignore
        new PagefindUI({ element: '#search', showSubResults: true });
      }
    });
  </script>
</BaseLayout>

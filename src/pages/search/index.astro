---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CodeWindow from '../../components/CodeWindow.astro';
---

<BaseLayout title="站内搜索" description="使用 Pagefind 搜索全文内容。">
  <div class="animate-fade-in max-w-3xl mx-auto">
    <!-- 页面标题 - 代码风格 -->
    <div class="mb-6">
      <h1 class="font-mono text-sm text-[var(--color-text-secondary)]">
        <span class="syntax-comment">// </span>
        <span class="syntax-variable">search</span>
        <span class="text-[var(--color-text-muted)]">.ts</span>
      </h1>
    </div>

    <!-- 搜索容器 -->
    <CodeWindow filename="query.ts">
      <div class="font-mono text-sm">
        <p class="syntax-comment">// 输入关键词搜索文章</p>
        <p class="syntax-comment">// 按 / 键可快速聚焦</p>
        <div id="search" class="mt-4"></div>
      </div>
    </CodeWindow>
  </div>

  <!-- Pagefind 样式覆盖 - 代码风格 -->
  <style is:global>
    :root {
      --pagefind-ui-scale: 1;
      --pagefind-ui-primary: var(--color-accent);
      --pagefind-ui-text: var(--color-text-primary);
      --pagefind-ui-background: transparent;
      --pagefind-ui-border: var(--color-border);
      --pagefind-ui-tag: var(--color-accent);
      --pagefind-ui-border-width: 1px;
      --pagefind-ui-border-radius: 4px;
      --pagefind-ui-image-border-radius: 4px;
      --pagefind-ui-image-box-ratio: 3 / 2;
      --pagefind-ui-font: 'JetBrains Mono', monospace;
    }

    /* 搜索表单容器 */
    .pagefind-ui__form {
      position: relative;
    }

    /* 搜索输入框 */
    .pagefind-ui__search-input {
      background: var(--color-surface) !important;
      border: 1px solid var(--color-border) !important;
      color: var(--color-text-primary) !important;
      transition: all 0.2s ease !important;
      font-size: 0.875rem !important;
      font-family: 'JetBrains Mono', monospace !important;
      padding: 0.625rem 1rem !important;
      height: auto !important;
      border-radius: 4px !important;
    }

    .pagefind-ui__search-input:focus {
      border-color: var(--color-accent) !important;
      box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.15) !important;
      outline: none !important;
    }

    .pagefind-ui__search-input::placeholder {
      color: var(--color-text-muted) !important;
      opacity: 1 !important;
    }

    /* 搜索清除按钮 */
    .pagefind-ui__search-clear {
      color: var(--color-text-secondary) !important;
      padding: 0.5rem !important;
      background: transparent !important;
    }

    .pagefind-ui__search-clear:hover {
      color: var(--color-text-primary) !important;
    }

    /* 结果容器 */
    .pagefind-ui__results-area {
      margin-top: 1.5rem !important;
    }

    /* 单个搜索结果 */
    .pagefind-ui__result {
      background: var(--color-surface) !important;
      border: 1px solid var(--color-border) !important;
      border-radius: 4px !important;
      padding: 1rem !important;
      margin-bottom: 0.75rem !important;
      transition: all 0.15s ease !important;
    }

    .pagefind-ui__result:hover {
      border-color: var(--color-accent) !important;
      background: var(--color-surface-hover) !important;
    }

    /* 结果标题链接 */
    .pagefind-ui__result-link {
      color: var(--color-accent) !important;
      font-weight: 500 !important;
      font-size: 0.875rem !important;
      text-decoration: none !important;
      display: block !important;
      margin-bottom: 0.375rem !important;
      font-family: 'JetBrains Mono', monospace !important;
    }

    .pagefind-ui__result-link:hover {
      text-decoration: underline !important;
    }

    /* 结果摘要 */
    .pagefind-ui__result-excerpt {
      color: var(--color-text-secondary) !important;
      line-height: 1.6 !important;
      margin-top: 0.375rem !important;
      font-size: 0.75rem !important;
    }

    /* 结果标签 */
    .pagefind-ui__result-tags {
      margin-top: 0.5rem !important;
      display: flex !important;
      flex-wrap: wrap !important;
      gap: 0.375rem !important;
    }

    .pagefind-ui__result-tag {
      background: var(--color-surface-elevated) !important;
      color: var(--color-text-secondary) !important;
      padding: 0.125rem 0.5rem !important;
      border-radius: 2px !important;
      font-size: 0.625rem !important;
      border: none !important;
      font-family: 'JetBrains Mono', monospace !important;
    }

    /* 消息提示 */
    .pagefind-ui__message {
      color: var(--color-text-secondary) !important;
      text-align: left !important;
      padding: 1rem 0 !important;
      font-size: 0.875rem !important;
      font-family: 'JetBrains Mono', monospace !important;
    }

    .pagefind-ui__message::before {
      content: '// ';
      color: var(--color-comment);
    }

    /* 加载更多按钮 */
    .pagefind-ui__button {
      background: var(--color-surface-elevated) !important;
      color: var(--color-text-secondary) !important;
      border-radius: 4px !important;
      transition: all 0.15s ease !important;
      padding: 0.5rem 1rem !important;
      font-weight: 500 !important;
      border: 1px solid var(--color-border) !important;
      cursor: pointer !important;
      margin: 1rem 0 !important;
      display: inline-block !important;
      font-size: 0.75rem !important;
      font-family: 'JetBrains Mono', monospace !important;
    }

    .pagefind-ui__button:hover {
      background: var(--color-surface-hover) !important;
      color: var(--color-text-primary) !important;
      border-color: var(--color-accent) !important;
    }

    /* 高亮标记 */
    mark.pagefind-ui__result-highlight {
      background: rgba(59, 130, 246, 0.2) !important;
      color: var(--color-accent) !important;
      padding: 0 2px;
      border-radius: 2px;
      font-weight: 500 !important;
    }

    /* 子结果（段落级别） */
    .pagefind-ui__result-nested {
      padding-left: 1rem !important;
      margin-top: 0.5rem !important;
      border-left: 2px solid var(--color-border) !important;
    }

    /* 隐藏图片 */
    .pagefind-ui__result-image {
      display: none !important;
    }

    /* 隐藏默认图标 */
    .pagefind-ui__form::before {
      display: none !important;
    }
  </style>

  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script src="/pagefind/pagefind-ui.js" type="text/javascript"></script>
  <script type="text/javascript">
    function initSearch() {
      const searchEl = document.getElementById('search');
      if (!searchEl) return;

      // 清空之前的内容
      searchEl.innerHTML = '';

      // @ts-ignore
      if (typeof PagefindUI !== 'undefined') {
        // @ts-ignore
        new PagefindUI({
          element: '#search',
          showSubResults: true,
          autofocus: true,
          translations: {
            placeholder: 'const query = "..."',
            zero_results: '未找到匹配结果',
            many_results: '找到 [COUNT] 条结果',
            one_result: '找到 1 条结果',
            alt_search: '尝试搜索 [TERM]',
            search_label: '搜索',
            filters_label: '筛选',
            load_more: '// 加载更多...',
          },
        });
      }
    }

    document.addEventListener('DOMContentLoaded', initSearch);

    window.addEventListener('keydown', (event) => {
      if (event.key === '/' && document.activeElement?.tagName !== 'INPUT') {
        event.preventDefault();
        const input = document.querySelector<HTMLInputElement>('#search input');
        if (input) input.focus();
      }
    });

    // 支持 Astro View Transitions
    document.addEventListener('astro:after-swap', initSearch);
  </script>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import CodeWindow from '../../components/CodeWindow.astro';
import Sidebar from '../../components/Sidebar.astro';
import { getCollection } from 'astro:content';
import {
  filterContentPosts,
  filterDrafts,
  getSeriesName,
  groupSeriesPosts,
  sortPosts,
} from '../../lib/utils';

const allPosts = sortPosts(filterDrafts(await getCollection('blog')));
const posts = filterContentPosts(allPosts);
const standalonePosts = posts.filter((post) => !getSeriesName(post));
const seriesEntries = groupSeriesPosts(allPosts);
---

<BaseLayout title="文章" description="所有文章列表" wide>
  <div class="flex flex-col lg:flex-row gap-8">
    <!-- 主内容区 -->
    <div class="flex-1 min-w-0">
      <!-- 页面标题 -->
      <div class="mb-6">
        <h1 class="font-mono text-sm text-[var(--color-text-secondary)]">
          <span class="syntax-comment">// </span>
          <span class="syntax-variable">posts</span>
          <span class="text-[var(--color-text-muted)]">/index.ts</span>
          <span class="ml-2 text-[var(--color-text-muted)]">({posts.length} 篇)</span>
        </h1>
      </div>

      <!-- 系列文章 -->
      {seriesEntries.map((group) => (
        <section class="mb-8">
          <div class="flex items-center justify-between mb-3">
            <h2 class="font-mono text-xs text-[var(--color-text-secondary)]">
              <span class="syntax-comment">// </span>
              <span class="syntax-keyword">我不知道的</span>
              <span class="syntax-type"> {group.name}</span>
              <span class="text-[var(--color-text-muted)]"> ({group.posts.length})</span>
            </h2>
            <a
              href={`/series/${encodeURIComponent(group.name)}/`}
              class="
                text-xs font-mono
                text-[var(--color-accent)]
                hover:underline
              "
            >
              查看系列 →
            </a>
          </div>

          {
            group.indexPost && (
              <a
                href={`/posts/${group.indexPost.slug}/`}
                class="
                  mb-3 block rounded border border-[var(--color-border)]
                  bg-[var(--color-surface-elevated)] p-3
                  text-sm text-[var(--color-text-secondary)]
                  hover:border-[var(--color-accent)]
                "
              >
                <span class="font-mono text-xs text-[var(--color-accent)]">系列导读</span>
                <p class="mt-1 font-medium text-[var(--color-text-primary)]">
                  {group.indexPost.data.title}
                </p>
              </a>
            )
          }

          <div class="space-y-3">
            {group.posts.slice(0, 3).map((post, index) => (
              <PostCard post={post} index={index} showSeries={false} />
            ))}
          </div>

          {group.posts.length > 3 && (
            <a
              href={`/series/${encodeURIComponent(group.name)}/`}
              class="
                mt-3 inline-flex items-center gap-1
                font-mono text-xs
                text-[var(--color-text-muted)]
                hover:text-[var(--color-accent)]
              "
            >
              <span>还有 {group.posts.length - 3} 篇...</span>
            </a>
          )}
        </section>
      ))}

      <!-- 独立文章 -->
      {standalonePosts.length > 0 && (
        <section>
          <h2 class="font-mono text-xs text-[var(--color-text-secondary)] mb-3">
            <span class="syntax-comment">// </span>
            <span class="syntax-variable">standalone</span>
            <span class="text-[var(--color-text-muted)]"> ({standalonePosts.length})</span>
          </h2>

          <div class="space-y-3">
            {standalonePosts.map((post, index) => (
              <PostCard post={post} index={index} showSeries={false} />
            ))}
          </div>
        </section>
      )}

      <!-- 空状态 -->
      {posts.length === 0 && (
        <CodeWindow filename="empty.ts">
          <p class="font-mono text-sm text-[var(--color-text-secondary)]">
            <span class="syntax-comment">// 暂无文章</span>
          </p>
        </CodeWindow>
      )}
    </div>

    <!-- 侧边栏 -->
    <Sidebar posts={posts} />
  </div>
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import CodeBlockEnhancer from '../../components/CodeBlockEnhancer.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import BackToTop from '../../components/BackToTop.astro';
import {
  estimateReadingTime,
  format,
  getSeriesName,
  getTagPath,
  isSeriesIndex,
} from '../../lib/utils';
import { siteConfig } from '../../lib/siteConfig';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
const canonical =
  post.data.canonical ?? new URL(`/posts/${post.slug}/`, siteConfig.siteUrl).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate,
  dateModified: post.data.updatedDate ?? post.data.pubDate,
  url: canonical,
  author: {
    '@type': 'Person',
    name: siteConfig.author,
  },
};
const readingTime = estimateReadingTime(post.body);
const seriesName = getSeriesName(post);
const seriesLink = seriesName ? `/series/${encodeURIComponent(seriesName)}/` : null;
const isIndex = isSeriesIndex(post);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonical={canonical}
  image={post.data.cover}
  keywords={post.data.keywords}
  lang={post.data.lang}
  jsonLd={jsonLd}
  wide={true}
>
  <!-- 阅读进度条 -->
  <ReadingProgress />

  <!-- 主体布局：文章 + TOC 侧边栏 -->
  <div class="relative lg:grid lg:grid-cols-[1fr_220px] lg:gap-8 xl:grid-cols-[1fr_260px]">
    <article class="animate-fade-in min-w-0">
      <!-- 文章头部 -->
      <header class="mb-8">
        <!-- 返回链接 -->
        <a
          href="/posts/"
          class="group text-text-secondary hover:text-accent mb-6 inline-flex items-center gap-2 text-sm font-medium transition-colors"
        >
          <Icon name="arrow-left" class="transition-transform group-hover:-translate-x-1" />
          <span>返回文章列表</span>
        </a>

        <!-- 元信息 -->
        <div class="text-text-secondary mb-4 flex flex-wrap items-center gap-4 text-sm">
          <!-- 发布日期 -->
          <div class="flex items-center gap-1.5">
            <Icon name="calendar" />
            <time datetime={post.data.pubDate.toISOString()}>
              {format.date(post.data.pubDate)}
            </time>
          </div>

          <!-- 阅读时间 -->
          <div class="flex items-center gap-1.5">
            <Icon name="clock" />
            <span>{readingTime}</span>
          </div>

          <!-- 更新日期 -->
          {
            post.data.updatedDate && (
              <div class="flex items-center gap-1.5">
                <Icon name="refresh" />
                <span>更新于 {format.date(post.data.updatedDate)}</span>
              </div>
            )
          }
        </div>

        {
          seriesLink && (
            <div class="mb-4 flex flex-wrap items-center gap-2 font-mono text-xs">
              <a
                href={seriesLink}
                class="inline-flex items-center gap-1 rounded bg-[var(--color-accent)]/10 px-2 py-1 text-[var(--color-accent)] transition-colors hover:bg-[var(--color-accent)]/15"
              >
                <Icon name="folder" size={3} />
                <span>{isIndex ? '系列导读' : `我不知道的 ${seriesName}`}</span>
              </a>
            </div>
          )
        }

        <!-- 标题 -->
        <h1 class="text-text-primary text-3xl leading-tight font-bold sm:text-4xl">
          {post.data.title}
        </h1>

        <!-- 描述 -->
        <p class="text-text-secondary mt-4 text-lg leading-relaxed">
          {post.data.description}
        </p>

        <!-- 标签 -->
        {
          post.data.tags && post.data.tags.length > 0 && (
            <div class="mt-6 flex flex-wrap gap-2 font-mono text-xs" aria-label="标签">
              {post.data.tags.map((tag) => (
                <a
                  href={getTagPath(tag)}
                  class="inline-flex items-center gap-1 rounded bg-[var(--color-surface-elevated)] px-2 py-1 text-[var(--color-text-secondary)] transition-colors hover:bg-[var(--color-accent)]/10 hover:text-[var(--color-accent)]"
                >
                  <span class="syntax-string">"{tag}"</span>
                </a>
              ))}
            </div>
          )
        }
      </header>

      <!-- 封面图 -->
      {
        post.data.cover && (
          <figure class="mb-10 overflow-hidden rounded border border-[var(--color-border)]">
            <img
              src={post.data.cover}
              alt={post.data.coverAlt || post.data.title}
              loading="eager"
              class="w-full object-cover"
            />
            {post.data.coverAlt && (
              <figcaption class="text-text-secondary mt-3 text-center text-sm">
                {post.data.coverAlt}
              </figcaption>
            )}
          </figure>
        )
      }

      <!-- 文章内容 -->
      <div
        class="prose prose-lg prose-headings:font-bold prose-a:text-accent prose-a:no-underline hover:prose-a:underline prose-img:rounded prose-img:shadow-lg prose-code:before:content-none prose-code:after:content-none max-w-none [&>h1:first-child]:hidden"
      >
        <Content />
      </div>

      <!-- 文章底部 -->
      <footer class="border-border mt-12 border-t pt-8">
        <!-- 分享提示 -->
        <div class="code-window">
          <div class="code-window-titlebar">
            <span class="flex-1 text-center font-mono text-xs text-[var(--color-text-secondary)]"
              >share.ts</span
            >
          </div>
          <div class="p-4 font-mono text-sm">
            <p class="syntax-comment">// 觉得这篇文章有帮助？</p>
            <p class="syntax-comment">// 欢迎分享给更多人</p>
            <p class="mt-4">
              <span class="syntax-keyword">export const</span>
              <span class="syntax-variable">&nbsp;subscribe</span>
              <span class="text-[var(--color-text-primary)]">&nbsp;=&nbsp;</span>
              <a href="/rss.xml" class="syntax-string hover:underline">"/rss.xml"</a>
              <span class="text-[var(--color-text-primary)]">;</span>
            </p>
          </div>
        </div>
      </footer>
    </article>

    <!-- TOC 侧边栏 - 仅在大屏幕显示 -->
    {
      headings.length > 0 && (
        <aside class="hidden lg:block">
          <TableOfContents headings={headings} />
        </aside>
      )
    }
  </div>

  <!-- 代码块增强 -->
  <CodeBlockEnhancer />

  <!-- 返回顶部按钮 -->
  <BackToTop />
</BaseLayout>

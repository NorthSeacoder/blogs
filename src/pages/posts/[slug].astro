---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import CodeBlockEnhancer from '../../components/CodeBlockEnhancer.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import BackToTop from '../../components/BackToTop.astro';
import { estimateReadingTime, format } from '../../lib/utils';
import { siteConfig } from '../../lib/siteConfig';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
const canonical =
  post.data.canonical ?? new URL(`/posts/${post.slug}/`, siteConfig.siteUrl).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate,
  dateModified: post.data.updatedDate ?? post.data.pubDate,
  url: canonical,
  author: {
    '@type': 'Person',
    name: siteConfig.author,
  },
};
const readingTime = estimateReadingTime(post.body);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonical={canonical}
  image={post.data.cover}
  keywords={post.data.keywords}
  lang={post.data.lang}
  jsonLd={jsonLd}
  wide={true}
>
  <!-- 阅读进度条 -->
  <ReadingProgress />

  <!-- 主体布局：文章 + TOC 侧边栏 -->
  <div class="relative lg:grid lg:grid-cols-[1fr_220px] lg:gap-8 xl:grid-cols-[1fr_260px]">
    <article class="animate-fade-in min-w-0">
      <!-- 文章头部 -->
      <header class="mb-8">
        <!-- 返回链接 -->
        <a
          href="/posts/"
          class="
            group mb-6 inline-flex items-center gap-2
            text-sm font-medium text-text-secondary
            transition-colors hover:text-accent
          "
        >
          <Icon name="arrow-left" class="transition-transform group-hover:-translate-x-1" />
          <span>返回文章列表</span>
        </a>

        <!-- 元信息 -->
        <div class="mb-4 flex flex-wrap items-center gap-4 text-sm text-text-secondary">
          <!-- 发布日期 -->
          <div class="flex items-center gap-1.5">
            <Icon name="calendar" />
            <time datetime={post.data.pubDate.toISOString()}>
              {format.date(post.data.pubDate)}
            </time>
          </div>

          <!-- 阅读时间 -->
          <div class="flex items-center gap-1.5">
            <Icon name="clock" />
            <span>{readingTime}</span>
          </div>

          <!-- 更新日期 -->
          {
            post.data.updatedDate && (
              <div class="flex items-center gap-1.5">
                <Icon name="refresh" />
                <span>更新于 {format.date(post.data.updatedDate)}</span>
              </div>
            )
          }
        </div>

        <!-- 标题 -->
        <h1 class="text-3xl font-bold leading-tight text-text-primary sm:text-4xl">
          {post.data.title}
        </h1>

        <!-- 描述 -->
        <p class="mt-4 text-lg leading-relaxed text-text-secondary">
          {post.data.description}
        </p>

        <!-- 标签 -->
        {
          post.data.tags && post.data.tags.length > 0 && (
            <div class="mt-6 flex flex-wrap gap-2" aria-label="标签">
              {post.data.tags.map((tag) => (
                <a
                  href={`/tags/${tag}/`}
                  class="
                    inline-flex items-center gap-1
                    rounded-full px-4 py-1.5
                    text-sm font-medium
                    bg-accent/10 text-accent
                    transition-all duration-200
                    hover:bg-accent/20 hover:scale-105
                  "
                >
                  <span class="opacity-60">#</span>
                  {tag}
                </a>
              ))}
            </div>
          )
        }
      </header>

      <!-- 封面图 -->
      {
        post.data.cover && (
          <figure class="mb-10 overflow-hidden rounded-2xl">
            <img
              src={post.data.cover}
              alt={post.data.coverAlt || post.data.title}
              loading="eager"
              class="w-full object-cover shadow-xl"
            />
            {post.data.coverAlt && (
              <figcaption class="mt-3 text-center text-sm text-text-secondary">
                {post.data.coverAlt}
              </figcaption>
            )}
          </figure>
        )
      }

      <!-- 文章内容 -->
      <div
        class="
          prose prose-lg
          prose-headings:font-bold
          prose-a:text-accent prose-a:no-underline hover:prose-a:underline
          prose-img:rounded-xl prose-img:shadow-lg
          prose-code:before:content-none prose-code:after:content-none
          max-w-none
        "
      >
        <Content />
      </div>

      <!-- 文章底部 -->
      <footer class="mt-12 border-t border-border pt-8">
        <!-- 分享提示 -->
        <div class="glass rounded-2xl p-6">
          <div class="flex flex-col items-center gap-4 text-center sm:flex-row sm:text-left">
            <div
              class="
                flex h-12 w-12 items-center justify-center
                rounded-full bg-accent/10 text-accent
              "
            >
              <Icon name="share" size={6} />
            </div>
            <div class="flex-1">
              <p class="font-semibold text-text-primary">觉得这篇文章有帮助？</p>
              <p class="text-sm text-text-secondary">欢迎分享给更多人，或者订阅 RSS 获取最新内容。</p>
            </div>
            <a
              href="/rss.xml"
              class="
                inline-flex items-center gap-2
                rounded-xl bg-accent px-5 py-2.5
                text-sm font-semibold text-white
                transition-all duration-300
                hover:shadow-lg hover:shadow-accent/25 hover:-translate-y-0.5
              "
            >
              <Icon name="rss" />
              <span>订阅 RSS</span>
            </a>
          </div>
        </div>
      </footer>
    </article>

    <!-- TOC 侧边栏 - 仅在大屏幕显示 -->
    {
      headings.length > 0 && (
        <aside class="hidden lg:block">
          <TableOfContents headings={headings} />
        </aside>
      )
    }
  </div>

  <!-- 代码块增强 -->
  <CodeBlockEnhancer />

  <!-- 返回顶部按钮 -->
  <BackToTop />
</BaseLayout>

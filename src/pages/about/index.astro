---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CodeWindow from '../../components/CodeWindow.astro';
import Icon from '../../components/Icon.astro';
import { siteConfig } from '../../lib/siteConfig';

// 兴趣爱好
const interests = ['前端工程化', '开发工具', 'VSCode 插件', '效率提升'];

// 开源项目
const projects = [
  { name: 'weekly', desc: 'AI 技术周刊', repo: 'https://github.com/NorthSeacoder/weekly' },
  { name: 'franky', desc: 'VSCode 提效插件', repo: 'https://github.com/NorthSeacoder/franky' },
  { name: 'codetransformer', desc: 'AST 代码迁移', repo: 'https://github.com/NorthSeacoder/codetransformer' },
];
---

<BaseLayout title="关于" description="关于作者与博客的介绍。" wide>
  <div class="animate-fade-in">
    <!-- 两列瀑布流布局 -->
    <div class="columns-1 md:columns-2 gap-4 space-y-4">
      <!-- 关于我 -->
      <CodeWindow filename="me.ts" class="break-inside-avoid">
        <div class="font-mono text-sm leading-relaxed">
          <p class="syntax-comment">/**</p>
          <p class="syntax-comment">&nbsp;*&nbsp;Hi, 我是 {siteConfig.author}</p>
          <p class="syntax-comment">&nbsp;*&nbsp;一个喜欢折腾工具的前端开发者</p>
          <p class="syntax-comment">&nbsp;*/</p>

          <p class="mt-4"><span class="syntax-keyword">const</span><span class="syntax-variable">&nbsp;me</span><span class="text-[var(--color-text-primary)]">&nbsp;=&nbsp;{'{'}</span></p>
          <p class="pl-4"><span class="syntax-variable">name</span><span class="text-[var(--color-text-primary)]">:&nbsp;</span><span class="syntax-string">"{siteConfig.author}"</span><span class="text-[var(--color-text-primary)]">,</span></p>
          <p class="pl-4"><span class="syntax-variable">location</span><span class="text-[var(--color-text-primary)]">:&nbsp;</span><span class="syntax-string">"北京"</span><span class="text-[var(--color-text-primary)]">,</span></p>
          <p class="pl-4"><span class="syntax-variable">focus</span><span class="text-[var(--color-text-primary)]">:&nbsp;[</span>{interests.map((item, i) => (<><span class="syntax-string">"{item}"</span>{i < interests.length - 1 && <span class="text-[var(--color-text-primary)]">,&nbsp;</span>}</>))}<span class="text-[var(--color-text-primary)]">],</span></p>
          <p class="text-[var(--color-text-primary)]">{'}'}</span><span class="text-[var(--color-text-primary)]">;</span></p>
        </div>
      </CodeWindow>

      <!-- 关于本站 -->
      <CodeWindow filename="blog.ts" class="break-inside-avoid">
        <div class="font-mono text-sm leading-relaxed">
          <p class="syntax-comment">/**</p>
          <p class="syntax-comment">&nbsp;*&nbsp;关于 ?.log</p>
          <p class="syntax-comment">&nbsp;*</p>
          <p class="syntax-comment">&nbsp;*&nbsp;记录那些"我不知道的 xxx"</p>
          <p class="syntax-comment">&nbsp;*&nbsp;探索未知的技术领域</p>
          <p class="syntax-comment">&nbsp;*/</p>

          <p class="mt-4"><span class="syntax-keyword">export default</span><span class="text-[var(--color-text-primary)]">&nbsp;{'{'}</span></p>
          <p class="pl-4"><span class="syntax-variable">framework</span><span class="text-[var(--color-text-primary)]">:&nbsp;</span><span class="syntax-string">"Astro"</span><span class="text-[var(--color-text-primary)]">,</span></p>
          <p class="pl-4"><span class="syntax-variable">styling</span><span class="text-[var(--color-text-primary)]">:&nbsp;</span><span class="syntax-string">"Tailwind CSS"</span><span class="text-[var(--color-text-primary)]">,</span></p>
          <p class="pl-4"><span class="syntax-variable">theme</span><span class="text-[var(--color-text-primary)]">:&nbsp;</span><span class="syntax-string">"VSCode Dark"</span><span class="text-[var(--color-text-primary)]">,</span></p>
          <p class="text-[var(--color-text-primary)]">{'}'}</span><span class="text-[var(--color-text-primary)]">;</span></p>
        </div>
      </CodeWindow>

      <!-- 联系方式 -->
      <CodeWindow filename="contact.ts" class="break-inside-avoid">
        <div class="font-mono text-sm leading-relaxed">
          <p class="syntax-comment">// 找到我</p>
          <p class="mt-2"><span class="syntax-keyword">export const</span><span class="syntax-variable">&nbsp;links</span><span class="text-[var(--color-text-primary)]">&nbsp;=&nbsp;{'{'}</span></p>
          <p class="pl-4"><span class="syntax-variable">github</span><span class="text-[var(--color-text-primary)]">:&nbsp;</span><span class="syntax-string">"github.com/NorthSeacoder"</span><span class="text-[var(--color-text-primary)]">,</span></p>
          <p class="pl-4"><span class="syntax-variable">email</span><span class="text-[var(--color-text-primary)]">:&nbsp;</span><span class="syntax-string">"{siteConfig.social.email}"</span><span class="text-[var(--color-text-primary)]">,</span></p>
          <p class="pl-4"><span class="syntax-variable">rss</span><span class="text-[var(--color-text-primary)]">:&nbsp;</span><span class="syntax-string">"/rss.xml"</span><span class="text-[var(--color-text-primary)]">,</span></p>
          <p class="text-[var(--color-text-primary)]">{'}'}</span><span class="text-[var(--color-text-primary)]">;</span></p>
        </div>

        <!-- 社交链接按钮 -->
        <div class="mt-4 pt-4 border-t border-[var(--color-border)] flex flex-wrap gap-2">
          <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 px-3 py-1.5 rounded text-xs font-mono bg-[var(--color-surface-elevated)] text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-text-primary)] hover:bg-[var(--color-surface-hover)]">
            <Icon name="github" size={3.5} />
            <span>GitHub</span>
          </a>
          <a href={`mailto:${siteConfig.social.email}`} class="flex items-center gap-1.5 px-3 py-1.5 rounded text-xs font-mono bg-[var(--color-surface-elevated)] text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-text-primary)] hover:bg-[var(--color-surface-hover)]">
            <Icon name="mail" size={3.5} />
            <span>Email</span>
          </a>
          <a href="/rss.xml" class="flex items-center gap-1.5 px-3 py-1.5 rounded text-xs font-mono bg-[var(--color-surface-elevated)] text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-text-primary)] hover:bg-[var(--color-surface-hover)]">
            <Icon name="rss" size={3.5} />
            <span>RSS</span>
          </a>
        </div>
      </CodeWindow>

      <!-- 开源项目 -->
      <CodeWindow filename="projects.ts" class="break-inside-avoid">
        <div class="font-mono text-sm leading-relaxed">
          <p class="syntax-comment">// 业余项目</p>
          <p class="mt-2"><span class="syntax-keyword">const</span><span class="syntax-variable">&nbsp;projects</span><span class="text-[var(--color-text-primary)]">&nbsp;=&nbsp;[</span></p>

          {projects.map((project, index) => (
            <p class="pl-4">
              <span class="text-[var(--color-text-primary)]">{'{'}&nbsp;</span>
              <a href={project.repo} target="_blank" rel="noopener noreferrer" class="syntax-string hover:underline">"{project.name}"</a>
              <span class="text-[var(--color-text-primary)]">:&nbsp;</span>
              <span class="syntax-string">"{project.desc}"</span>
              <span class="text-[var(--color-text-primary)]">&nbsp;{'}'}{index < projects.length - 1 ? ',' : ''}</span>
            </p>
          ))}

          <p class="text-[var(--color-text-primary)]">];</p>
        </div>
      </CodeWindow>
    </div>
  </div>
</BaseLayout>

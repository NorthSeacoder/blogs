---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import CodeWindow from '../components/CodeWindow.astro';
import Sidebar from '../components/Sidebar.astro';
import Icon from '../components/Icon.astro';
import { getCollection } from 'astro:content';
import { filterDrafts, sortPosts } from '../lib/utils';
import { siteConfig } from '../lib/siteConfig';

const posts = sortPosts(filterDrafts(await getCollection('blog')));
const latest = posts.slice(0, 5);
---

<BaseLayout title={siteConfig.title} description={siteConfig.description} wide>
  <div class="flex flex-col lg:flex-row gap-8">
    <!-- 主内��区 -->
    <div class="flex-1 min-w-0">
      <!-- Hero 区域 - 终端风格 -->
      <section class="mb-8 animate-fade-in">
        <CodeWindow filename="terminal.ts">
          <div class="font-mono text-sm leading-relaxed">
            <!-- 注释 -->
            <p class="syntax-comment">/**</p>
            <p class="syntax-comment"> * @author {siteConfig.author}</p>
            <p class="syntax-comment"> * @role {siteConfig.bio}</p>
            <p class="syntax-comment"> */</p>

            <p class="mt-4"><span class="syntax-keyword">const</span><span class="syntax-variable"> developer</span><span class="text-[var(--color-text-primary)]">&nbsp;=&nbsp;{'{'}</span></p>
            <p class="pl-4"><span class="syntax-variable">name</span><span class="text-[var(--color-text-primary)]">:&nbsp;</span><span class="syntax-string">"{siteConfig.author}"</span><span class="text-[var(--color-text-primary)]">,</span></p>
            <p class="pl-4"><span class="syntax-variable">role</span><span class="text-[var(--color-text-primary)]">:&nbsp;</span><span class="syntax-string">"{siteConfig.bio}"</span><span class="text-[var(--color-text-primary)]">,</span></p>
            <p class="pl-4"><span class="syntax-variable">skills</span><span class="text-[var(--color-text-primary)]">:&nbsp;[</span>{siteConfig.skills.map((skill, i) => (<><span class="syntax-string">"{skill}"</span>{i < siteConfig.skills.length - 1 && <span class="text-[var(--color-text-primary)]">,&nbsp;</span>}</>))}<span class="text-[var(--color-text-primary)]">],</span></p>
            <p class="text-[var(--color-text-primary)]">{'}'}</span><span class="text-[var(--color-text-primary)]">;</span></p>

            <p class="mt-4"><span class="syntax-variable">console</span><span class="text-[var(--color-text-primary)]">.</span><span class="syntax-function">log</span><span class="text-[var(--color-text-primary)]">(</span><span class="syntax-string">"Welcome to my blog!"</span><span class="text-[var(--color-text-primary)]">)</span><span class="text-[var(--color-text-primary)]">;</span><span class="cursor-blink ml-0.5 inline-block w-[2px] h-[1em] bg-[var(--color-accent)] align-text-bottom"></span></p>
          </div>

          <!-- 社交链接 -->
          <div class="mt-6 pt-4 border-t border-[var(--color-border)] flex gap-3">
            {siteConfig.social.github && (
              <a
                href={siteConfig.social.github}
                target="_blank"
                rel="noopener noreferrer"
                class="
                  flex items-center gap-1.5
                  px-3 py-1.5 rounded
                  text-xs font-mono
                  bg-[var(--color-surface-elevated)]
                  text-[var(--color-text-secondary)]
                  transition-colors
                  hover:text-[var(--color-text-primary)]
                  hover:bg-[var(--color-surface-hover)]
                "
              >
                <Icon name="github" size={3.5} />
                <span>GitHub</span>
              </a>
            )}
            {siteConfig.social.email && (
              <a
                href={`mailto:${siteConfig.social.email}`}
                class="
                  flex items-center gap-1.5
                  px-3 py-1.5 rounded
                  text-xs font-mono
                  bg-[var(--color-surface-elevated)]
                  text-[var(--color-text-secondary)]
                  transition-colors
                  hover:text-[var(--color-text-primary)]
                  hover:bg-[var(--color-surface-hover)]
                "
              >
                <Icon name="mail" size={3.5} />
                <span>Email</span>
              </a>
            )}
            <a
              href="/rss.xml"
              class="
                flex items-center gap-1.5
                px-3 py-1.5 rounded
                text-xs font-mono
                bg-[var(--color-surface-elevated)]
                text-[var(--color-text-secondary)]
                transition-colors
                hover:text-[var(--color-text-primary)]
                hover:bg-[var(--color-surface-hover)]
              "
            >
              <Icon name="rss" size={3.5} />
              <span>RSS</span>
            </a>
          </div>
        </CodeWindow>
      </section>

      <!-- 最新文章 -->
      <section class="space-y-4" aria-labelledby="latest-posts">
        <div class="flex items-center justify-between">
          <h2 id="latest-posts" class="font-mono text-sm text-[var(--color-text-secondary)]">
            <span class="syntax-comment">// </span>
            <span class="syntax-variable">latest-posts</span>
            <span class="text-[var(--color-text-muted)]">.ts</span>
          </h2>
          <a
            href="/posts/"
            class="
              group flex items-center gap-1
              text-xs font-mono
              text-[var(--color-accent)]
              transition-colors hover:text-[var(--color-accent-hover)]
            "
          >
            <span>查看全部</span>
            <Icon name="chevron-right" size={3} class="transition-transform group-hover:translate-x-0.5" />
          </a>
        </div>

        <!-- 文章列表 -->
        <div class="space-y-3">
          {latest.map((post, index) => <PostCard post={post} index={index} />)}
        </div>

        <!-- 空状态 -->
        {
          latest.length === 0 && (
            <CodeWindow filename="empty.ts">
              <p class="font-mono text-sm text-[var(--color-text-secondary)]">
                <span class="syntax-comment">// 暂无文章，敬请期待...</span>
              </p>
            </CodeWindow>
          )
        }
      </section>
    </div>

    <!-- 侧边栏 -->
    <Sidebar posts={posts} />
  </div>
</BaseLayout>

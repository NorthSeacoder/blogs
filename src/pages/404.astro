---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
---

<BaseLayout title="页面未找到" description="抱歉，页面不存在。">
  <div class="flex min-h-[60vh] flex-col items-center justify-center text-center animate-fade-in">
    <!-- 404 图形 -->
    <div class="relative mb-8">
      <div
        class="
          text-[10rem] font-black leading-none
          bg-gradient-to-br from-accent via-cyan-500 to-accent
          bg-clip-text text-transparent
          opacity-20
        "
      >
        404
      </div>
      <div
        class="
          absolute inset-0 flex items-center justify-center
          text-6xl font-bold text-text-primary
        "
      >
        Oops!
      </div>
    </div>

    <!-- 错误信息 -->
    <div class="glass rounded-2xl p-8 max-w-md">
      <h1 class="text-2xl font-bold text-text-primary">页面未找到</h1>
      <p class="mt-3 text-text-secondary">
        链接可能已失效或页面已被移动。别担心，试试下面的选项：
      </p>

      <!-- 操作按钮 -->
      <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:justify-center">
        <a
          href="/"
          class="
            group inline-flex items-center justify-center gap-2
            rounded-xl bg-accent px-6 py-3
            text-sm font-semibold text-white
            shadow-lg shadow-accent/25
            transition-all duration-300
            hover:shadow-xl hover:shadow-accent/30 hover:-translate-y-0.5
          "
        >
          <Icon name="home" class="transition-transform group-hover:-translate-x-1" />
          <span>返回首页</span>
        </a>
        <a
          href="/search/"
          class="
            group inline-flex items-center justify-center gap-2
            rounded-xl glass px-6 py-3
            text-sm font-semibold text-text-primary
            transition-all duration-300
            hover:shadow-lg hover:-translate-y-0.5
          "
        >
          <Icon name="search" />
          <span>站内搜索</span>
        </a>
      </div>
    </div>

    <!-- 建议链接 -->
    <div class="mt-8 text-sm text-text-secondary">
      <p>或者浏览：</p>
      <div class="mt-2 flex flex-wrap justify-center gap-4">
        <a href="/posts/" class="text-accent hover:underline">文章列表</a>
        <a href="/tags/" class="text-accent hover:underline">标签</a>
        <a href="/archives/" class="text-accent hover:underline">归档</a>
        <a href="/about/" class="text-accent hover:underline">关于</a>
      </div>
    </div>
  </div>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { filterDrafts } from '../../lib/utils';

const posts = filterDrafts(await getCollection('blog'));
const tagMap = new Map<string, number>();
posts.forEach((post) => {
  post.data.tags?.forEach((tag) => {
    tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
  });
});
const tags = Array.from(tagMap.entries()).sort(([a], [b]) => a.localeCompare(b));
---

<BaseLayout title="标签" description="查看所有标签与文章数量。">
  <div class="animate-fade-in">
    <!-- 页面标题 -->
    <div class="mb-8">
      <div class="flex items-center gap-3">
        <div class="h-8 w-1 rounded-full bg-gradient-to-b from-accent to-cyan-500"></div>
        <h1 class="text-3xl font-bold text-text-primary">标签</h1>
      </div>
      <p class="mt-2 text-text-secondary">探索你感兴趣的主题。</p>
    </div>

    <!-- 标签云 -->
    {
      tags.length > 0 ? (
        <ul class="flex flex-wrap gap-3" aria-label="标签列表">
          {tags.map(([tag, count], index) => (
            <li
              class="animate-slide-up animate-fill-backwards"
              style={`animation-delay: ${index * 50}ms;`}
            >
              <a
                href={`/tags/${tag}/`}
                class="
                  group inline-flex items-center gap-2
                  rounded-full
                  glass
                  px-5 py-2.5
                  text-sm font-medium
                  transition-all duration-300
                  hover:shadow-lg hover:scale-105 hover:-translate-y-0.5
                "
              >
                <span class="text-accent">#</span>
                <span class="text-text-primary group-hover:text-accent transition-colors">{tag}</span>
                <span
                  class="
                    flex h-6 w-6 items-center justify-center
                    rounded-full bg-accent/10 text-xs font-semibold text-accent
                  "
                >
                  {count}
                </span>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <div class="glass rounded-2xl p-12 text-center">
          <p class="text-text-secondary">暂无标签</p>
        </div>
      )
    }
  </div>
</BaseLayout>

---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import CodeWindow from '../../../components/CodeWindow.astro';
import Icon from '../../../components/Icon.astro';
import { getCollection } from 'astro:content';
import { filterDrafts, sortPosts } from '../../../lib/utils';

export async function getStaticPaths() {
  const posts = filterDrafts(await getCollection('blog'));
  const tags = new Set<string>();
  posts.forEach((post) => post.data.tags?.forEach((tag) => tags.add(tag)));

  return Array.from(tags).map((tag) => ({
    params: { tag },
    props: { tag, posts: sortPosts(posts.filter((p) => p.data.tags?.includes(tag))) },
  }));
}

const { tag, posts } = Astro.props as {
  tag: string;
  posts: Awaited<ReturnType<typeof getCollection<'blog'>>>;
};
---

<BaseLayout title={`标签：${tag}`} description={`${tag} 相关的文章列表`} wide>
  <div class="animate-fade-in">
    <!-- 返回链接 -->
    <a
      href="/tags/"
      class="
        group mb-4 inline-flex items-center gap-1.5
        font-mono text-xs text-[var(--color-text-secondary)]
        transition-colors hover:text-[var(--color-accent)]
      "
    >
      <Icon name="arrow-left" size={3} class="transition-transform group-hover:-translate-x-1" />
      <span>../tags/</span>
    </a>

    <!-- 页面标题 -->
    <div class="mb-6">
      <h1 class="font-mono text-sm text-[var(--color-text-secondary)]">
        <span class="syntax-comment">// </span>
        <span class="syntax-variable">tags</span>
        <span class="text-[var(--color-text-muted)]">/</span>
        <span class="syntax-string">"{tag}"</span>
        <span class="text-[var(--color-text-muted)]">.ts</span>
      </h1>
      <p class="mt-2 font-mono text-xs text-[var(--color-text-muted)]">
        // 共 <span class="syntax-number">{posts.length}</span> 篇文章
      </p>
    </div>

    <!-- 文章列表 -->
    {posts.length > 0 ? (
      <div class="space-y-3">
        {posts.map((post, index) => <PostCard post={post} index={index} />)}
      </div>
    ) : (
      <CodeWindow filename="empty.ts">
        <p class="font-mono text-sm text-[var(--color-text-secondary)]">
          <span class="syntax-comment">// 该标签下暂无文章</span>
        </p>
      </CodeWindow>
    )}
  </div>
</BaseLayout>

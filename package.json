{
  "name": "astro-blog",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=20.3.0"
  },
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "start": "npm run dev",
    "build": "astro build && pagefind",
    "preview": "astro preview",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint \"src/**/*.{astro,js,mjs,cjs,ts}\" \"scripts/**/*.{js,mjs,cjs,ts}\" astro.config.mjs tailwind.config.ts",
    "format": "prettier . --write",
    "tags:normalize": "node scripts/normalize-tags.mjs",
    "import:drafts": "node scripts/import-blog-drafts.mjs",
    "validate": "node scripts/validate-frontmatter.mjs",
    "validate:watch": "node --watch scripts/validate-frontmatter.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "4.3.4",
    "@astrojs/rss": "4.0.12",
    "@astrojs/sitemap": "3.6.0",
    "@iconify-json/lucide": "^1.2.84",
    "@pagefind/default-ui": "1.4.0",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.1.13",
    "astro": "5.16.5",
    "astro-icon": "^1.1.5",
    "pagefind": "1.4.0",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "7.1.0",
    "rehype-slug": "6.0.0",
    "remark-gfm": "4.0.1",
    "sharp": "0.34.5",
    "tailwindcss": "4.1.13"
  },
  "devDependencies": {
    "@types/node": "^25.0.2",
    "@typescript-eslint/eslint-plugin": "8.46.3",
    "@typescript-eslint/parser": "8.46.3",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-astro": "1.3.1",
    "gray-matter": "^4.0.3",
    "prettier": "3.7.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.7.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}
